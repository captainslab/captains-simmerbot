# Core trading credentials
SIMMER_API_KEY=
SIMMER_AGENT_ID=
SIMMER_AGENT_NAME=btc-sprint-stack-20260402
SIMMER_BASE_URL=https://api.simmer.markets

# Wallet mode
# Leave blank to use the managed (server-signed) wallet.
WALLET_PRIVATE_KEY=

# LLM provider options
#   codex         — OpenAI Codex OAuth (reads ~/.codex/auth.json or CODEX_OAUTH_TOKEN)
#   google_oauth  — uses gcloud ADC (run: gcloud auth application-default login)
#   google        — Gemini API key
#   deepseek      — DeepSeek API key
#   openai        — OpenAI API key
#   openrouter    — OpenRouter API key
LLM_PROVIDER=codex
LLM_MODEL=codex-mini-latest
LLM_API_KEY=

# Market / venue settings
BINANCE_SYMBOL=BTCUSDT
BINANCE_INTERVAL=1m
TRADING_VENUE=polymarket

# Discord control and alerts
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# Portable install overrides
BTC_SPRINT_SECRETS_FILE=
BTC_SPRINT_APPS_ROOT=
BTC_SPRINT_SKILL_LIBRARY=
BTC_SPRINT_TMUX_SESSION=
BTC_SPRINT_TMUX_MAIN_WIN=
BTC_SPRINT_PYTHON_BIN=

# Bot defaults
BTC_SPRINT_DRY_RUN=1
BTC_SPRINT_VALIDATE_REAL_PATH=1
BTC_SPRINT_WINDOWS=5m,15m
BTC_SPRINT_PROFILE=balanced
