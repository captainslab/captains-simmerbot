SIMMER_API_KEY=
SIMMER_AGENT_ID=
# External Polygon wallet (recommended). Set to your 0x private key to enable
# self-custody signing. Triggers one-time link_wallet + set_approvals on startup
# and auto_redeem each live cycle. Leave blank to use the managed (server-signed) wallet.
WALLET_PRIVATE_KEY=
SIMMER_AGENT_NAME=btc-sprint-stack-20260402
SIMMER_BASE_URL=https://api.simmer.markets
# LLM provider options:
#   codex         — OpenAI Codex OAuth (no API key; reads ~/.codex/auth.json or CODEX_OAUTH_TOKEN)
#   deepseek      — DeepSeek API key
#   openai        — OpenAI API key
#   openrouter    — OpenRouter API key
LLM_PROVIDER=codex
LLM_MODEL=codex-mini-latest
LLM_API_KEY=
BINANCE_SYMBOL=BTCUSDT
BINANCE_INTERVAL=1m
TRADING_VENUE=polymarket
DISCORD_WEBHOOK_URL=
# Discord control mode. Enable the Message Content intent in the Discord developer portal.
DISCORD_BOT_TOKEN=
# Comma-separated Discord user IDs allowed to control the bot.
DISCORD_ALLOWED_USER_IDS=
DISCORD_CONTROL_CHANNEL_ID=
# Optional legacy prefix for command-style control. Natural language works without it.
DISCORD_CONTROL_PREFIX=simmer:
BTC_SPRINT_DRY_RUN=1
BTC_SPRINT_VALIDATE_REAL_PATH=1
BTC_SPRINT_WINDOWS=5m,15m
BTC_SPRINT_PROFILE=balanced
