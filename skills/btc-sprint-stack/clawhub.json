{
  "version": "0.2.2",
  "emoji": "btc",
  "requires": {
    "pip": [
      "simmer-sdk",
      "eth-account",
      "requests",
      "discord.py"
    ],
    "env": [
      "SIMMER_API_KEY",
      "LLM_API_KEY",
      "DISCORD_BOT_TOKEN",
      "DISCORD_ALLOWED_USER_IDS",
      "DISCORD_CONTROL_CHANNEL_ID"
    ]
  },
  "cron": "*/15 * * * *",
  "automaton": {
    "managed": true,
    "entrypoint": "main.py"
  }
}
